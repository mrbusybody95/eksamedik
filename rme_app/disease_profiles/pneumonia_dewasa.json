{
  "_comment": "Disease Profile: Pneumonia Dewasa — CAP/HAP adult pneumonia",
  "_version": "1.0",
  "name": "Pneumonia Dewasa",
  "version": "1.0",
  "description": "Ekstraksi data pneumonia dewasa (CAP/HAP). Includes CURB-65, procalcitonin, blood culture, thorax PA, oksigen, ventilasi.",
  "drug_profile": "pneumonia.json",
  "field_types": {
    "curb65_score": "numeric",
    "demo_age": "numeric",
    "fisik_bb": "numeric",
    "fisik_imt": "numeric",
    "fisik_tb": "numeric",
    "hr": "numeric",
    "lab_albumin": "numeric",
    "lab_alt": "numeric",
    "lab_ast": "numeric",
    "lab_crp": "numeric",
    "lab_gds": "numeric",
    "lab_hb": "numeric",
    "lab_kalium": "numeric",
    "lab_kreatinin": "numeric",
    "lab_leukosit": "numeric",
    "lab_natrium": "numeric",
    "lab_pct": "numeric",
    "lab_trombosit": "numeric",
    "lab_ureum": "numeric",
    "lama_rawat_hari": "numeric",
    "oksigen_lpm": "numeric",
    "pao2_fio2": "numeric",
    "rr": "numeric",
    "spo2": "numeric",
    "suhu": "numeric",
    "suhu_tertinggi": "numeric",
    "td_diastol": "numeric",
    "td_sistol": "numeric"
  },
  "categories": {
    "Demografi": {
      "fields": [
        "demo_age",
        "demo_gender",
        "jenis_kelamin"
      ],
      "type": "builtin",
      "extractor": "demographics",
      "desc": "Usia + Jenis Kelamin"
    },
    "Diagnosis": {
      "fields": [
        "diagnosis_utama",
        "diagnosis_sekunder",
        "pneumonia_klasifikasi",
        "icd_code"
      ],
      "type": "regex",
      "patterns": {
        "diagnosis_utama": "(?i)diagnos[aei]\\s*(?:utama)?\\s*[:=]?\\s*(.{5,200})",
        "diagnosis_sekunder": "(?i)diagnos[aei]\\s*(?:sekunder|tambahan|lain)\\s*[:=]?\\s*(.{5,200})",
        "pneumonia_klasifikasi": "(?i)(CAP|HAP|VAP|community\\s*acquired|hospital\\s*acquired|ventilator)\\s*(?:pneumonia)?",
        "icd_code": "(?i)J18\\.[0-9]|J15\\.[0-9]|J14|J13|J12\\.[0-9]"
      },
      "doc_types": [
        "resume",
        "cppt_igd",
        "cppt_ranap"
      ],
      "desc": "CAP/HAP/VAP + kode ICD"
    },
    "CURB-65": {
      "fields": [
        "curb65_score",
        "curb65_confusion",
        "curb65_ureum",
        "curb65_rr",
        "curb65_bp",
        "curb65_age65",
        "curb65_kategori",
        "psi_class"
      ],
      "type": "regex",
      "patterns": {
        "curb65_score": "(?i)curb[-\\s]?65\\s*[:=]?\\s*(\\d)",
        "curb65_confusion": "(?i)(confusion|b[ia]ngung|dis[oe]rientasi).*(?:ada|positif|\\+|ya)|(?:ada|positif|\\+|ya).*(confusion|b[ia]ngung|dis[oe]rientasi)",
        "curb65_ureum": "(?i)(?:ureum|BUN|urea).*(?:>\\s*7|[tu]inggi)|(?:>\\s*7|[tu]inggi).*(?:ureum|BUN)",
        "curb65_rr": "(?i)(?:pernapasan|respiratory|RR).*(?:≥\\s*30|lebih.*30|30\\s*x|takipn)",
        "curb65_bp": "(?i)(?:tekanan\\s*darah|TD|sistolik).*(?:<\\s*90|<\\s*60|hipoten[sz])",
        "curb65_age65": "(?i)usia.*(?:≥\\s*65|lebih.*65|diatas\\s*65)",
        "curb65_kategori": "(?i)CURB[-\\s]?65.*?(ringan|sedang|berat|rendah|tinggi|risiko)",
        "psi_class": "(?i)(?:PSI|pneumonia\\s*severity\\s*index)\\s*(?:class|kelas|score)?\\s*[:=]?\\s*([IVX]+|\\d+)"
      },
      "doc_types": [
        "cppt_igd",
        "cppt_ranap",
        "resume"
      ],
      "desc": "Skor CURB-65 komponen + kategori + PSI class"
    },
    "Vital Sign": {
      "fields": [
        "td_sistol",
        "td_diastol",
        "hr",
        "rr",
        "suhu",
        "spo2"
      ],
      "type": "builtin",
      "extractor": "vitals",
      "desc": "TD, HR, RR, Suhu, SpO2 dari CPPT IGD"
    },
    "Oksigen & Ventilasi": {
      "fields": [
        "oksigen_terapi",
        "oksigen_lpm",
        "hfnc",
        "niv",
        "ventilasi_mekanik",
        "pao2_fio2"
      ],
      "type": "regex",
      "patterns": {
        "oksigen_terapi": "(?i)(?:oksigen|O2)\\s*(?:terapi|therap[yi])?\\s*[:=]?\\s*(.{3,80})",
        "oksigen_lpm": "(?i)(\\d+(?:\\.\\d+)?)\\s*(?:lpm|L/m|liter)",
        "hfnc": "(?i)(HFNC|high\\s*flow|high-flow)",
        "niv": "(?i)(NIV|NPPV|BiPAP|CPAP|non-?invasif)",
        "ventilasi_mekanik": "(?i)(ventilasi\\s*mekanik|ventilator|intubasi|ETT)",
        "pao2_fio2": "(?i)(?:PaO2|P/F)\\s*[:/]\\s*FiO2\\s*[:=]?\\s*(\\d+)"
      },
      "doc_types": [
        "cppt_igd",
        "cppt_ranap"
      ],
      "desc": "Oksigen terapi, HFNC, NIV, ventilasi mekanik, PaO2/FiO2 ratio"
    },
    "Laboratorium": {
      "fields": [
        "lab_hb",
        "lab_leukosit",
        "lab_trombosit",
        "lab_gds",
        "lab_ureum",
        "lab_kreatinin",
        "lab_natrium",
        "lab_kalium",
        "lab_crp",
        "lab_pct",
        "lab_albumin",
        "lab_ast",
        "lab_alt"
      ],
      "type": "builtin",
      "extractor": "lab_values",
      "desc": "HB, leukosit, trombosit, GDS, ureum, kreatinin, CRP, procalcitonin, albumin, SGOT/SGPT"
    },
    "Kultur & Sensitivitas": {
      "fields": [
        "kultur_darah",
        "kultur_sputum",
        "kultur_lain",
        "gram_stain",
        "sensitivitas",
        "kuman_terdeteksi"
      ],
      "type": "regex",
      "patterns": {
        "kultur_darah": "(?i)(?:blood\\s*culture|kultur\\s*da(?:rh|rah))\\s*[:=]?\\s*(.{3,200})",
        "kultur_sputum": "(?i)(?:sputum\\s*culture|kultur\\s*sputum|BCS)\\s*[:=]?\\s*(.{3,200})",
        "kultur_lain": "(?i)(?:kultur|culture)\\s*(?:lain|other|sekresi|pleura)\\s*[:=]?\\s*(.{3,200})",
        "gram_stain": "(?i)(?:gram\\s*stain|pewarnaan\\s*gram|apusan)\\s*[:=]?\\s*(.{3,200})",
        "sensitivitas": "(?i)(?:sensitivit[aai]|sensitivity|antibio(?:g)?)\\s*[:=]?\\s*(.{3,200})",
        "kuman_terdeteksi": "(?i)(?:kuman|bakteri|pathogen|organisme)\\s*(?:terdeteksi|ditemukan|positif)\\s*[:=]?\\s*(.{3,100})"
      },
      "doc_types": [
        "lab",
        "cppt_ranap",
        "resume"
      ],
      "desc": "Hasil kultur darah, sputum, gram stain, sensitivitas antibiotik"
    },
    "Tanggal Laboratorium": {
